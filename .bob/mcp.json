{
    "mcpServers": {
        "content-repository": {
            "command": "uvx",
            "args": [
                "--from",
                "git+https://github.com/ibm-ecm/ibm-content-services-mcp-server",
                "core-cs-mcp-server"
            ],
            "env": {
                "USERNAME": "bob-doc-service.fid@t7026",
